{
  "version": 2,
  "builds": [
    { "src": "**", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/.well-known/stellar.toml",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
